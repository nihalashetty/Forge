# Forge API configuration. Copy to apps/api/.env (local) or set as real env vars (prod).
# Every value is optional locally — the defaults run on SQLite + embedded Chroma + in-process
# cache with NO external infra. The production guard (FORGE_ENVIRONMENT != dev) refuses to
# boot with the insecure defaults below, so set the *** values before deploying.

# --- Environment ---
# development | test | staging | production. Anything other than the local-dev names
# (development/dev/local/test) enables the hardening guard and fails closed.
FORGE_ENVIRONMENT=development

# --- Security (CHANGE THESE OUTSIDE DEV) ---
FORGE_JWT_SECRET=***generate-a-long-random-string***
# Optional: previously-active signing secrets accepted during key rotation (JSON list).
# FORGE_JWT_SECRET_PREVIOUS=["old-secret-1"]
FORGE_BOOTSTRAP_ADMIN_EMAIL=admin@yourco.com
FORGE_BOOTSTRAP_ADMIN_PASSWORD=***choose-a-strong-password***

# --- Persistence (prod = Postgres) ---
# FORGE_DATABASE_URL=postgresql+asyncpg://forge:password@postgres:5432/forge
# FORGE_CHECKPOINT_BACKEND=postgres            # sqlite (dev) | memory | postgres (prod/HITL)
# FORGE_CHECKPOINT_POSTGRES_URL=               # defaults to FORGE_DATABASE_URL

# --- Cache / queue / limits (prod = Redis, shared across workers) ---
# FORGE_REDIS_URL=redis://redis:6379/0

# --- Public URLs ---
FORGE_PUBLIC_BASE_URL=http://localhost:8000
FORGE_PUBLIC_CONSOLE_URL=http://localhost:3000

# --- CORS / hosts / proxy (JSON lists) ---
FORGE_CORS_ORIGINS=["http://localhost:3000"]
# FORGE_TRUSTED_HOSTS=["forge.yourco.com"]     # empty = any (dev only)
# FORGE_TRUSTED_PROXIES=["10.0.0.0/8"]         # IPs whose X-Forwarded-For we believe

# --- Scaling (single scheduler leader; bound concurrent runs per tenant) ---
# FORGE_ENABLE_SCHEDULER=true                  # turn on for exactly ONE instance
# FORGE_SCHEDULER_LEADER=true
# FORGE_MAX_CONCURRENT_RUNS_PER_TENANT=20

# --- Public embed abuse limits ---
# FORGE_EMBED_RATE_LIMIT_PER_MINUTE=60
# FORGE_EMBED_RATE_LIMIT_PER_IP_PER_MINUTE=20

# --- Tools (code execution is OFF by default; not OS-isolated) ---
# FORGE_ENABLE_CODE_TOOLS=false
# FORGE_ALLOW_UNSANDBOXED_CODE_TOOLS=false     # explicit opt-in to run code tools in prod

# --- Model provider keys (set the ones you use) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# --- Observability (optional OTLP export) ---
# FORGE_OTEL_ENABLED=true
# FORGE_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
