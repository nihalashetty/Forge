# Forge — environment configuration. Copy to apps/api/.env and edit.
# All backend vars are prefixed FORGE_. Local defaults need NO external infra.

# --- Core ---
FORGE_ENVIRONMENT=development           # set "production" to enforce the safety checks below
FORGE_DEBUG=true

# --- Persistence (SQLite default; Postgres REQUIRED in production) ---
# FORGE_DATABASE_URL=postgresql+psycopg://forge:forge@localhost:5432/forge
# FORGE_CHECKPOINT_DB=postgres          # or a sqlite file path; default: apps/api/.data/checkpoints.sqlite

# --- Vectors (Chroma; embedded persistent by default) ---
# FORGE_CHROMA_PATH=./apps/api/.data/chroma

# --- Cache / queue (in-process locally; Redis in multi-worker prod) ---
# FORGE_REDIS_URL=redis://localhost:6379/0

# --- Platform auth ---
FORGE_JWT_SECRET=dev-insecure-change-me   # MUST be a strong random value in production
# FORGE_AUTH_REQUIRED=false              # true => every request needs a JWT (flip on once login is set up)
# FORGE_ALLOW_OPEN_SIGNUP=true           # false => only admins invite users
# FORGE_BOOTSTRAP_ADMIN_EMAIL=you@forge.local
# FORGE_BOOTSTRAP_ADMIN_PASSWORD=        # set so the seeded owner can log in once auth is enabled

# --- SSRF egress guard (applies to all outbound tool/webhook/fetch/ingest calls) ---
# FORGE_EGRESS_BLOCK_PRIVATE=true        # keep true in prod (blocks private/metadata IPs)
# FORGE_EGRESS_ALLOW_HOSTS=["api.example.com"]   # if set, ONLY these hosts (+subdomains) are allowed
# FORGE_EGRESS_DENY_HOSTS=[]

# --- Rate limits / quotas (per tenant; 0 = unlimited; per-day caps live in tenant.settings) ---
# FORGE_RUN_RATE_LIMIT_PER_MINUTE=60
# FORGE_API_RATE_LIMIT_PER_MINUTE=240

# --- Tools ---
# FORGE_ENABLE_CODE_TOOLS=true           # disable in untrusted multi-tenant installs
# FORGE_MAX_TOOL_RESPONSE_CHARS=20000

# --- Triggers / scheduler ---
# FORGE_ENABLE_SCHEDULER=true            # disable on extra workers; run one global scheduler

# --- OAuth / channels: public base URL of THIS API (redirect URIs, webhook URLs) ---
# FORGE_PUBLIC_BASE_URL=https://forge.yourco.com

# --- Team invites: where the web console is served (used to build invite links) ---
# FORGE_PUBLIC_CONSOLE_URL=https://app.forge.yourco.com

# --- Outbound email (SMTP) for team invites. Leave SMTP_HOST unset to disable sending —
# the invite UI then shows a copyable link instead. Works with any relay (Postmark/SES/…). ---
# FORGE_SMTP_HOST=smtp.postmarkapp.com
# FORGE_SMTP_PORT=587
# FORGE_SMTP_USERNAME=
# FORGE_SMTP_PASSWORD=
# FORGE_SMTP_USE_TLS=true
# FORGE_SMTP_FROM=Forge <no-reply@yourco.com>

# --- Observability (OpenTelemetry; install the `observability` extra) ---
# FORGE_OTEL_ENABLED=false
# FORGE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces   # or a Langfuse OTLP endpoint
# FORGE_OTEL_SERVICE_NAME=forge

# --- Default model ---
FORGE_DEFAULT_MODEL=fake:echo            # offline-safe; set a real provider model + key for live runs
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Frontend (apps/web) ---
NEXT_PUBLIC_FORGE_API_URL=http://localhost:8000

# ============================================================================
# PRODUCTION CHECKLIST (the app refuses to boot if these are wrong when
# FORGE_ENVIRONMENT=production — see settings.validate_production):
#   1. FORGE_JWT_SECRET set to a strong random value
#   2. FORGE_AUTH_REQUIRED=true
#   3. FORGE_EGRESS_BLOCK_PRIVATE=true
#   4. FORGE_DATABASE_URL points at Postgres (not SQLite)
#   Then: `alembic upgrade head` (+ apply infra/postgres_rls.sql for RLS), restart.
# ============================================================================
